<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="750.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sismanis.fitnesstracker.ShellController">
   <left>
      <VBox prefWidth="150.0" spacing="10.0" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
         <children>
            <Button fx:id="navWorkoutsButton" maxWidth="1.7976931348623157E308" onAction="#showWorkoutsView" text="Προπονήσεις" />
            <Button fx:id="navGoalsButton" maxWidth="1.7976931348623157E308" onAction="#showGoalsView" text="Στόχοι" />
            
         </children>
         <BorderPane.margin>
            <Insets right="5.0" />
         </BorderPane.margin>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="contentArea" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>