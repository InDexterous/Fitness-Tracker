<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sismanis.fitnesstracker.WorkoutViewController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <left>
        <VBox prefWidth="320.0" spacing="8.0" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-weight: bold;" text="Προπόνηση:">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>
                <Label text="Ημερομηνία:" />
                <DatePicker fx:id="datePicker" prefWidth="300.0" promptText="Επιλογή ημερομηνίας" />
                <Label text="Είδος Προπόνησης:" />
                <HBox spacing="5.0">
                    <children>
                        <ComboBox fx:id="typeComboBox" prefWidth="245.0" promptText="Επιλογή είδους" HBox.hgrow="ALWAYS" />
                        <Button fx:id="manageWorkoutTypesButton" onAction="#handleManageWorkoutTypes" prefWidth="50.0" text="..." />
                    </children>
                </HBox>
                <Label text="Διάρκεια (λεπτά):" />
                <TextField fx:id="durationField" prefWidth="300.0" promptText="π.χ. 30" />
                <Label text="Θερμίδες:" />
                <TextField fx:id="caloriesField" prefWidth="300.0" promptText="π.χ. 350" />
                <Label text="Απόσταση:" />
                <TextField fx:id="distanceField" prefWidth="300.0" promptText="π.χ. 5.5 (km)" />
                <Label style="-fx-font-style: italic;" text="Στόχοι Προπόνησης (προαιρετικά):" />
                <Label text="Στόχος Διάρκειας (λεπτά):" />
                <TextField fx:id="goalDurationField" prefWidth="300.0" promptText="π.χ. 45" />
                <Label text="Στόχος Θερμίδων:" />
                <TextField fx:id="goalCaloriesField" prefWidth="300.0" promptText="π.χ. 400" />
                <Label text="Σημειώσεις Προπόνησης:" />
                <TextArea fx:id="notesArea" prefHeight="100.0" prefWidth="300.0" promptText="Πρόσθετες σημειώσεις..." wrapText="true" />
                <Button fx:id="addButton" defaultButton="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddSession" style="-fx-font-size: 14px;" text="Προσθήκη / Αποθήκευση" />
            </children>
            <BorderPane.margin>
                <Insets right="20.0" />
            </BorderPane.margin>
        </VBox>
    </left>
    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Label text="Καταγεγραμμένες Προπονήσεις:">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <TableView fx:id="sessionsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="dateCol" prefWidth="100.0" text="Ημερομηνία" />
                        <TableColumn fx:id="typeCol" prefWidth="100.0" text="Είδος" />
                        <TableColumn fx:id="durationCol" prefWidth="75.0" text="Διάρκεια" />
                        <TableColumn fx:id="caloriesCol" prefWidth="75.0" text="Θερμίδες" />
                        <TableColumn fx:id="distanceCol" prefWidth="90.0" text="Απόσταση" />
                        <TableColumn fx:id="goalDurationCol" prefWidth="90.0" text="Στόχ. Διάρκ." />
                        <TableColumn fx:id="goalCaloriesCol" prefWidth="90.0" text="Στόχ. Θερμ." />
                        <TableColumn fx:id="notesCol" minWidth="100.0" prefWidth="150.0" text="Σημειώσεις" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="editButton" mnemonicParsing="false" onAction="#handleEditSession" style="-fx-font-size: 13px;" text="Επεξεργασία" />
                        <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDeleteSession" style="-fx-font-size: 13px;" text="Διαγραφή" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>